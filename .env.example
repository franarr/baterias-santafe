# ── Autenticación del panel admin ──────────────────────────────
# OBLIGATORIO en producción: si falta, el login no firma/valida tokens.
JWT_SECRET="cambiar-por-una-cadena-larga-y-aleatoria"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cambiar-antes-de-produccion"

# ── Base de datos (Turso / libSQL) ─────────────────────────────
# OBLIGATORIO en producción (Vercel). En local podés dejarlo vacío
# para usar el archivo SQLite ./dev.db
TURSO_DATABASE_URL="libsql://tu-base.turso.io"
TURSO_AUTH_TOKEN="tu-token-turso"

# ── AWS S3 — requerido para subir imágenes de productos ────────
AWS_REGION="sa-east-1"
AWS_ACCESS_KEY_ID="TU_ACCESS_KEY"
AWS_SECRET_ACCESS_KEY="TU_SECRET_KEY"
AWS_S3_BUCKET="nombre-del-bucket"
